# Model artifacts (often large)
# =========================
*.pt
*.pth
*.ckpt
*.tar.gz
*.zip

# =========================
# Python / notebooks
# =========================
__pycache__/
*.pyc
.ipynb_checkpoints/

# =========================
# Editor / OS
# =========================
.DS_Store
.vscode/

# =========================
# Logs (KEEP logs tracked)
