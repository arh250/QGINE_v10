# =========================
# Environments / installers
# =========================
miniconda3/
.venv/
env/
Miniconda3-latest-*.sh*
Miniconda3-latest-*.sh*.*

# =========================
# Big datasets / caches
# =========================
qm9_data/
data/
op2_cache*/
cache*/
*cache*/

# =========================
# Runs / outputs
